generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Tenants (fabricantes clientes do SaaS) ───────────────────────────────────
model Tenant {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now()) @map("created_at")

  stores       Store[]
  funnelStages FunnelStage[]
  leads        Lead[]
  leadEvents   LeadEvent[]
  users        User[]
  quotes       Quote[]
  adMetrics      AdMetricDaily[]
  adDemographics AdDemographic[]
  adSearchTerms  AdSearchTerm[]
  adCreatives    AdCreative[]
  adGeoMetrics   AdGeoMetric[]
  trafficGoals   TrafficGoal[]

  @@map("tenants")
}

// ─── Lojas ────────────────────────────────────────────────────────────────────
model Store {
  id         String  @id @default(uuid())
  tenantId   String  @map("tenant_id")
  name       String
  city       String?
  state      String?
  externalId String? @map("external_id")
  storeType  String  @default("splash") @map("store_type") // "splash" | "igui"

  tenant     Tenant      @relation(fields: [tenantId], references: [id])
  leads      Lead[]
  leadEvents LeadEvent[]
  quotes     Quote[]
  crmConfigs StoreCrmConfig[]
  adMetrics      AdMetricDaily[]
  adDemographics AdDemographic[]
  adSearchTerms  AdSearchTerm[]
  adCreatives    AdCreative[]
  adGeoMetrics   AdGeoMetric[]
  trafficGoals   TrafficGoal[]

  @@unique([tenantId, externalId])
  @@index([tenantId])
  @@map("stores")
}

// ─── Etapas do funil ──────────────────────────────────────────────────────────
model FunnelStage {
  id         String  @id @default(uuid())
  tenantId   String  @map("tenant_id")
  key        String
  label      String
  orderIndex Int     @map("order_index")
  isWon      Boolean @default(false) @map("is_won")
  isLost     Boolean @default(false) @map("is_lost")

  tenant          Tenant      @relation(fields: [tenantId], references: [id])
  leadsAsCurrent  Lead[]      @relation("CurrentStage")
  eventsFromStage LeadEvent[] @relation("FromStage")
  eventsToStage   LeadEvent[] @relation("ToStage")

  @@unique([tenantId, key])
  @@unique([tenantId, orderIndex])
  @@map("funnel_stages")
}

// ─── Leads ────────────────────────────────────────────────────────────────────
model Lead {
  id             String    @id @default(uuid())
  tenantId       String    @map("tenant_id")
  storeId        String    @map("store_id")
  externalId     String    @map("external_id")
  currentStageId String?   @map("current_stage_id")
  enteredAt            DateTime  @map("entered_at")
  closedAt             DateTime? @map("closed_at")
  firstResponseMinutes Int?      @map("first_response_minutes")
  salespersonCrmId     String?   @map("salesperson_crm_id")
  metadata             Json      @default("{}")
  estimatedValue       Float?    @map("estimated_value")
  revenue              Float?
  revenueCurrency      String?   @default("BRL") @map("revenue_currency")
  revenueAt            DateTime? @map("revenue_at")
  contactName          String?   @map("contact_name")
  contactPhone         String?   @map("contact_phone")
  salespersonName      String?   @map("salesperson_name")
  origemManual         String?   @map("origem_manual") // override manual: "meta"|"google"|"instagram"|"organico"
  utmSource            String?   @map("utm_source")
  utmMedium            String?   @map("utm_medium")
  utmCampaign          String?   @map("utm_campaign")
  utmContent           String?   @map("utm_content")

  tenant       Tenant       @relation(fields: [tenantId], references: [id])
  store        Store        @relation(fields: [storeId], references: [id])
  currentStage FunnelStage? @relation("CurrentStage", fields: [currentStageId], references: [id])
  events       LeadEvent[]

  @@unique([tenantId, externalId])
  @@index([tenantId, storeId])
  @@index([tenantId, currentStageId])
  @@index([tenantId, salespersonCrmId])
  @@index([tenantId, revenueAt])
  @@index([tenantId, utmCampaign])
  @@map("leads")
}

// ─── Eventos de transição (event sourcing) ────────────────────────────────────
model LeadEvent {
  id             String   @id @default(uuid())
  tenantId       String   @map("tenant_id")
  storeId        String   @map("store_id")
  leadId         String   @map("lead_id")
  fromStageId    String?  @map("from_stage_id")
  toStageId      String   @map("to_stage_id")
  occurredAt     DateTime @map("occurred_at")
  receivedAt     DateTime @default(now()) @map("received_at")
  idempotencyKey String   @unique @map("idempotency_key")
  rawPayload     Json?    @map("raw_payload")

  tenant    Tenant       @relation(fields: [tenantId], references: [id])
  store     Store        @relation(fields: [storeId], references: [id])
  lead      Lead         @relation(fields: [leadId], references: [id])
  fromStage FunnelStage? @relation("FromStage", fields: [fromStageId], references: [id])
  toStage   FunnelStage  @relation("ToStage",   fields: [toStageId],   references: [id])

  @@index([tenantId, storeId, occurredAt(sort: Desc)])
  @@index([tenantId, toStageId, occurredAt(sort: Desc)])
  @@index([leadId, occurredAt(sort: Desc)])
  @@map("lead_events")
}

// ─── Enum de roles ───────────────────────────────────────────────────────────
enum UserRole {
  admin
  fabricante
  lojista
  vendedor
  analista_crm
}

// ─── Usuários do sistema ──────────────────────────────────────────────────────
model User {
  id             String   @id @default(uuid())
  tenantId       String   @map("tenant_id")
  email          String
  passwordHash   String   @map("password_hash")
  name           String
  role           UserRole @default(fabricante)
  storeIds       Json     @default("[]") @map("store_ids")
  avatarInitials String   @map("avatar_initials")
  salesGoal      Int?     @map("sales_goal")
  crmUserId      String?  @map("crm_user_id")
  createdAt      DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, email])
  @@index([tenantId])
  @@map("users")
}

// ─── Orçamentos ───────────────────────────────────────────────────────────────
model Quote {
  id            String    @id @default(uuid())
  tenantId      String    @map("tenant_id")
  storeId       String    @map("store_id")
  vendedorId    String?   @map("vendedor_id")
  vendedorName  String    @map("vendedor_name")
  clientName    String    @map("client_name")
  proposalValue Float     @map("proposal_value")
  status        String    @default("pendente") // "pendente" | "ganho" | "perdido"
  formData      Json      @map("form_data")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt     @map("updated_at")
  wonAt         DateTime? @map("won_at")
  lostAt        DateTime? @map("lost_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])
  store  Store  @relation(fields: [storeId],  references: [id])

  @@index([tenantId, storeId,    createdAt(sort: Desc)])
  @@index([tenantId, status,     createdAt(sort: Desc)])
  @@index([tenantId, vendedorId, createdAt(sort: Desc)])
  @@map("quotes")
}

// ─── Configuração de CRM por loja ────────────────────────────────────────────
model StoreCrmConfig {
  id              String   @id @default(uuid())
  storeId         String   @map("store_id")
  crmSource       String   @default("helena") @map("crm_source") // "helena"
  panelId         String   @map("panel_id")
  helenaTokenEnc  String   @map("helena_token_enc")  // AES-256-GCM ciphertext (hex)
  helenaTokenIv   String   @map("helena_token_iv")   // IV (hex, 12 bytes)
  helenaTokenTag  String   @map("helena_token_tag")  // Auth tag (hex, 16 bytes)
  stageMap        Json     @map("stage_map")         // [{tagId, stepId, dashKey}]
  stagePriority   Json     @map("stage_priority")    // [tagId, ...] ordem de prioridade
  version         Int      @default(1)
  updatedBy       String?  @map("updated_by")
  updatedAt       DateTime @updatedAt @map("updated_at")
  createdAt       DateTime @default(now()) @map("created_at")

  store    Store               @relation(fields: [storeId], references: [id])
  audits   StoreCrmConfigAudit[]

  @@unique([storeId, crmSource])
  @@index([storeId])
  @@map("store_crm_configs")
}

model StoreCrmConfigAudit {
  id          String   @id @default(uuid())
  configId    String   @map("config_id")
  changedBy   String?  @map("changed_by")
  changedAt   DateTime @default(now()) @map("changed_at")
  snapshotJson Json    @map("snapshot_json") // estado antes da mudança

  config StoreCrmConfig @relation(fields: [configId], references: [id])

  @@index([configId, changedAt(sort: Desc)])
  @@map("store_crm_config_audits")
}

// ─── Tokens de reset de senha ─────────────────────────────────────────────────
model PasswordResetToken {
  id        String    @id @default(uuid())
  email     String
  token     String    @unique
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@index([token])
  @@index([email])
  @@map("password_reset_tokens")
}

// ─── Eventos com falha na ingestão (reprocessamento) ─────────────────────────
model FailedEvent {
  id         String   @id @default(uuid())
  receivedAt DateTime @default(now()) @map("received_at")
  payload    Json
  error      String
  source     String   @default("webhook")
  resolved   Boolean  @default(false)

  @@index([resolved, receivedAt(sort: Desc)])
  @@map("failed_events")
}

// ─── Métricas diárias de Ads (Google + Meta) ──────────────────────────────────
model AdMetricDaily {
  id          String   @id @default(uuid())
  tenantId    String   @map("tenant_id")
  storeId     String   @map("store_id")
  platform    String   // "google" | "meta"
  date        DateTime @db.Date
  spend       Float    @default(0)
  impressions Int      @default(0)
  clicks      Int      @default(0)
  leads       Int      @default(0)
  sales       Int      @default(0)
  revenue     Float    @default(0)
  messages    Int      @default(0) // Meta only

  tenant Tenant @relation(fields: [tenantId], references: [id])
  store  Store  @relation(fields: [storeId],  references: [id])

  @@unique([tenantId, storeId, platform, date])
  @@index([tenantId, storeId, date(sort: Desc)])
  @@index([tenantId, platform, date(sort: Desc)])
  @@map("ad_metrics_daily")
}

// ─── Segmentação demográfica de Ads ──────────────────────────────────────────
model AdDemographic {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  storeId   String   @map("store_id")
  platform  String   // "google" | "meta"
  date      DateTime @db.Date
  dimension String   // "age" | "gender" | "device"
  bucket    String   // ex: "18-24", "male", "mobile"
  leads     Int      @default(0)
  spend     Float    @default(0)
  clicks    Int      @default(0)
  impressions Int    @default(0)

  tenant Tenant @relation(fields: [tenantId], references: [id])
  store  Store  @relation(fields: [storeId],  references: [id])

  @@index([tenantId, storeId, platform, date(sort: Desc)])
  @@index([tenantId, platform, dimension])
  @@map("ad_demographics")
}

// ─── Termos de pesquisa (Google Ads) ─────────────────────────────────────────
model AdSearchTerm {
  id          String   @id @default(uuid())
  tenantId    String   @map("tenant_id")
  storeId     String   @map("store_id")
  periodStart DateTime @map("period_start") @db.Date
  periodEnd   DateTime @map("period_end")   @db.Date
  term        String
  impressions Int      @default(0)
  clicks      Int      @default(0)
  conversions Int      @default(0)
  cost        Float    @default(0)

  tenant Tenant @relation(fields: [tenantId], references: [id])
  store  Store  @relation(fields: [storeId],  references: [id])

  @@index([tenantId, storeId, periodStart(sort: Desc)])
  @@map("ad_search_terms")
}

// ─── Criativos de anúncio (Meta Ads) ─────────────────────────────────────────
model AdCreative {
  id          String   @id @default(uuid())
  tenantId    String   @map("tenant_id")
  storeId     String   @map("store_id")
  externalId  String   @map("external_id")
  name        String
  type        String   @default("image") // "image" | "video" | "carousel"
  subPlatform String?  @map("sub_platform") // "facebook" | "instagram" | "reels"
  leads       Int      @default(0)
  messages    Int      @default(0)
  spend       Float    @default(0)
  ctr         Float    @default(0)
  periodStart DateTime @map("period_start") @db.Date
  periodEnd   DateTime @map("period_end")   @db.Date

  tenant Tenant @relation(fields: [tenantId], references: [id])
  store  Store  @relation(fields: [storeId],  references: [id])

  @@index([tenantId, storeId, periodStart(sort: Desc)])
  @@map("ad_creatives")
}

// ─── Métricas geográficas de Ads ──────────────────────────────────────────────
model AdGeoMetric {
  id       String   @id @default(uuid())
  tenantId String   @map("tenant_id")
  storeId  String   @map("store_id")
  platform String   // "google" | "meta"
  date     DateTime @db.Date
  state    String   // UF de 2 letras (ex: "PR", "SP")
  leads    Int      @default(0)
  spend    Float    @default(0)
  clicks   Int      @default(0)

  tenant Tenant @relation(fields: [tenantId], references: [id])
  store  Store  @relation(fields: [storeId],  references: [id])

  @@index([tenantId, storeId, platform, date(sort: Desc)])
  @@index([tenantId, platform, state])
  @@map("ad_geo_metrics")
}

// ─── Metas anuais de tráfego por loja ────────────────────────────────────────
model TrafficGoal {
  id             String @id @default(uuid())
  tenantId       String @map("tenant_id")
  storeId        String @map("store_id")
  year           Int
  investmentGoal Float  @default(0) @map("investment_goal")
  leadsGoal      Int    @default(0) @map("leads_goal")
  salesGoal      Int    @default(0) @map("sales_goal")
  revenueGoal    Float  @default(0) @map("revenue_goal")

  tenant Tenant @relation(fields: [tenantId], references: [id])
  store  Store  @relation(fields: [storeId],  references: [id])

  @@unique([tenantId, storeId, year])
  @@index([tenantId, storeId])
  @@map("traffic_goals")
}
